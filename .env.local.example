# ─── TapGoods API credentials ─────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

TAPGOODS_API_KEY=your_api_key_here

# Optional — only needed if your API key is not already scoped to a business/location
# TAPGOODS_BUSINESS_ID=your_business_id_here
# TAPGOODS_LOCATION_ID=your_location_id_here

# ─── Supabase (client-side auth) ──────────────────────────────────────────────
# Required for @supabase/ssr session handling and profiles table queries.
# Safe to expose to the browser (anon key, RLS enforced).
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Supabase (server-side only) ──────────────────────────────────────────────
# Used by /api/upload-photo — POD photo storage + stops table writeback.
# Never expose SUPABASE_SERVICE_KEY to the browser (no NEXT_PUBLIC_ prefix).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Dashboard API (cross-app) ────────────────────────────────────────────────
# Origin of the partytime-dashboard deployment — the driver app POSTs/PATCHes
# /api/work-orders on this host when a driver files an issue. The dashboard
# route is RLS-gated by the same supabase project, validates the caller's
# bearer token, writes field_work_orders, and triggers the assignee email.
# Production: https://dashboard.partytimerentals.com
# Local dev:  http://localhost:3000 (or whatever port the dashboard runs on)
NEXT_PUBLIC_DASHBOARD_URL=https://dashboard.partytimerentals.com

# ─── AVA TTS (ElevenLabs) ─────────────────────────────────────────────────────
# Used by src/lib/ava/elevenLabs.ts to synthesize the AVA morning brief and
# (future) per-stop intel. The voice ID is hardcoded; only the API key is
# configurable. Exposed in the browser bundle (NEXT_PUBLIC_) because the
# driver app is gated to authenticated PTR employees — not the public.
# Without this key, speak() falls through silently to the Web Speech API.
NEXT_PUBLIC_ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ─── AVA Phase 2 — SOP sync (server-side only) ───────────────────────────────
# Notion integration token used by POST /api/sop/sync to read the SOP Library
# page and mirror it into sop_entries. NOT NEXT_PUBLIC — server-only secret.
# The integration must be shared into the "SOP Library" Notion page. Without
# this, /api/sop/sync returns 501 and never touches the DB.
NOTION_API_KEY=your-notion-integration-token-here
# Optional shared secret so a cron can call /api/sop/sync without a user
# session: send it as the `x-sop-sync-secret` request header. If unset, the
# route falls back to requiring an authenticated session.
SOP_SYNC_SECRET=

# ─── RFID module (feat/rfid-native-integration) ──────────────────────────────
# Easy RFID Pro base URL. DEFAULTS TO THE SANDBOX; the client refuses writes to
# any other host unless EASY_RFID_ALLOW_PRODUCTION=true is ALSO set. Never
# hardcode a host in code — this env var is the only switch.
EASY_RFID_BASE_URL=https://sb-easyrfidpro.ptshome.com
# Login host if it differs from the base URL (production: login.cloud.ptshome.com)
# EASY_RFID_AUTH_URL=
# Item Master table path if the sandbox UUID differs from production
# EASY_RFID_ITEM_MASTER_PATH=/api/v1/data/14223767938169344381
EASY_RFID_USERNAME=
EASY_RFID_PASSWORD=
# DO NOT SET in normal operation — production-write escape hatch.
# EASY_RFID_ALLOW_PRODUCTION=true

# TapGoods write-back: anything except the literal string 'false' means
# DRY-RUN (payloads logged, never sent). Going live ALSO requires an explicit
# allowLive flag at the module composition root — one env var cannot flip it.
TAPGOODS_DRY_RUN=true
