.next/
out/

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Build output ─────────────────────────────────────────────────────────────
dist/
build/

